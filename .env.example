# Example environment file for local builds.
# Copy this file to .env and replace the sample values as needed.

# Optional: GitHub token for local CLI tooling.
GITHUB_TOKEN=ghp_your_token_here

# Required by the toolkit build step.
TOOLKIT_DOWNLOAD_URL=https://github.com/ukoquique-proves/favoriteDevPage/releases/download/v0.1.0/ops-core

